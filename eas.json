{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "APP_VARIANT": "preview"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
      "production": {
        "autoIncrement": true,
        "channel": "production",
        "distribution": "internal",
        "env": {
          "APP_VARIANT": "production"
        }
      },
      "development": {
        "distribution": "internal",
        "channel": "development",
        "env": {
          "APP_VARIANT": "development"
        },
        "android": {
          "buildType": "apk"
        },
        "ios": {
          "simulator": true
        }
      }
  },
  "submit": {
  }
}
